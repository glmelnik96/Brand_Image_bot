# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/

# Env / secrets
.env
.env.local
*.secret

# Recon artifacts (могут содержать токены!)
recon/captures/
user_data/
*.har
*.har.gz
session.json
session.json.*
*.bak-stale
storage_state.json

# Logs
logs/
*.log

# Runtime caches / bot-state (не для коммита)
bot/tmp/
bot/regen_cache/
storage/brand_docs.json
storage/*.flag
outputs/

# Test/recon результаты — могут содержать AWS-подписанные URL, user_id и
# изображения пользователей. Никогда не коммитить.
tests/results/
recon/results/

# Пользовательские фотографии в input/ — face-данные. Допускается коммитить
# только заведомо обезличенные ассеты с явным пермитом.
input/*.jpg
input/*.jpeg
input/*.png
input/*.webp

# OS / IDE
.DS_Store
._*
Thumbs.db
.idea/
.vscode/

# OMC
.omc/
.claude/
