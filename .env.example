# Phygital
PHYGITAL_BASE_URL=https://app.phygital.plus
PHYGITAL_EMAIL=
PHYGITAL_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=
# CSV user_id'ов, кто допущен к боту. Пусто = открыт всем (НЕ рекомендуется).
TELEGRAM_ALLOWED_USER_IDS=
# HTTP-прокси для api.telegram.org (например, корпоративный kwts). Пусто = без прокси.
# Формат: http://HOST:PORT
TELEGRAM_PROXY_URL=
# PEM/DER с CA от прокси (kwts.pem). Нужен из-за MITM. Пусто = брать через truststore
# (системный keychain: macOS Keychain / Windows Cert Store / Linux CA bundle).
# Примеры:
#   Windows: TELEGRAM_PROXY_CERT=C:\Users\<user>\Documents\proxycert\kwts.pem
#   macOS:   TELEGRAM_PROXY_CERT=/Users/<user>/Documents/proxycert/kwts.pem
TELEGRAM_PROXY_CERT=
# Глобальный лимит одновременных Phygital-генераций.
BOT_MAX_CONCURRENCY=5
# CSV uid'ов, которым доступна админ-статистика по фидбэку (кнопка
# «Статистика» в подменю «Обратная связь»). Пусто = админский режим выключен.
BOT_OWNER_UIDS=

# Storage
REDIS_URL=redis://localhost:6379/0
SESSION_FILE=storage/session.json

# Logging
LOG_LEVEL=INFO
