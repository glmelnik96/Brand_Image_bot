# Phygital
PHYGITAL_BASE_URL=https://app.phygital.plus
PHYGITAL_EMAIL=
PHYGITAL_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=
# CSV user_id'ов, кто допущен к боту. Пусто = открыт всем (НЕ рекомендуется).
TELEGRAM_ALLOWED_USER_IDS=
# HTTP-прокси для api.telegram.org (Cloud.ru kwts). Пусто = без прокси.
TELEGRAM_PROXY_URL=http://192.168.1.65:3128
# PEM с CA от прокси (kwts.pem). Нужен из-за MITM. Пусто = брать через truststore (keychain).
TELEGRAM_PROXY_CERT=/Users/gmmelnikov/Documents/proxycert/kwts.pem
# Глобальный лимит одновременных Phygital-генераций.
BOT_MAX_CONCURRENCY=5

# Storage
REDIS_URL=redis://localhost:6379/0
SESSION_FILE=storage/session.json

# Logging
LOG_LEVEL=INFO
